<!DOCTYPE html>
<html>
<head>
    <title>Edit Course</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<h2>Edit Course</h2>

<form action="/courses/<%= course._id %>" method="POST">
    
    <!-- courseName NOT editable -->
    <input type="text" value="<%= course.courseName %>" disabled>

    <input type="number" name="price" value="<%= course.price %>" required>
    <input type="text" name="image" value="<%= course.image %>" required>
    <input type="text" name="duration" value="<%= course.duration %>" required>
    <input type="date" name="courseStartDate" value="<%= course.courseStartDate.toISOString().split('T')[0] %>" required>

    <button type="submit">Update</button>
</form>

</body>
</html>